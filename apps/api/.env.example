APP_NAME=OopSeller
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Manual macOS development: no database server is required.
DB_CONNECTION=sqlite
DB_FOREIGN_KEYS=true

# Local-only defaults. Change these for production.
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@oopseller.test
MAIL_FROM_NAME=OopSeller

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_SPAPI_APPLICATION_ID=
AMAZON_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/amazon/callback
AMAZON_DEFAULT_REGION=eu
AMAZON_SPAPI_SANDBOX=false
AMAZON_SPAPI_DRAFT=true
AMAZON_SPAPI_TIMEOUT=30
AMAZON_SPAPI_RETRY_TIMES=3
AMAZON_SPAPI_USER_AGENT="OopSeller/1.0 (Language=PHP; Platform=Laravel)"

RANK_PROVIDER=null
RANK_PROVIDER_API_KEY=
